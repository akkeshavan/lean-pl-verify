theorem charon_isZero_nonzero (x : Int) (hx : x ≠ 0) :
    evalFun [] IsZeroFun 10 [.int x] at () |= .pureOutput (· = .bool_ false) := by
  refine ⟨.bool_ false, (), ?_, rfl⟩
