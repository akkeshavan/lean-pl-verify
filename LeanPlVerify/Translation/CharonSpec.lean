/-
  Translation/CharonSpec.lean

  Theorems for the Charon-extracted LLBCFunDef terms in CharonDefs.lean.

  This file proves the SAME functional-correctness properties as ElabSpec.lean,
  but against LLBCFunDef terms that were AUTOMATICALLY GENERATED by the pipeline:

    verified_fns.rs  →  charon cargo  →  verified_fns.llbc  →  charon2lean.py  →  CharonDefs.lean

  The proof shapes are identical to ElabSpec.lean:
    · Straight-line:  ⟨witness, (), rfl, rfl⟩
    · With overflow:  refine ⟨…, (), ?_, rfl⟩; simp[…]; rw [if_pos h]; rfl
    · Branching:      simp [decide_eq_true h]  /  simp [decide_eq_false …]
    · Ground numeric: ⟨.int N, (), rfl, rfl⟩

  Key difference from ElabSpec: Charon emits more temporaries (explicit copy
  locals for operands, overflow-check booleans from AddChecked/SubChecked).
  These extra locals are "dead" for the proofs — the simp reduction passes
  through them transparently.

  C17 (pow): 5 theorems — pow_zero (symbolic), ground instances ×3, nocrash.
  C18 (gcd): 5 theorems — gcd_zero (symbolic), ground instances ×3, nocrash.

  Theorem count: 57, sorry count: 0.
-/

import Mathlib.Tactic
import LeanPlVerify.Translation.CharonDefs
import LeanPlVerify.Spec.Satisfies

namespace LeanPlVerify.LLBC.CharonSpec

open LeanPlVerify LeanPlVerify.LLBC LeanPlVerify.LLBC.Charon

-- Shared simp set for all Charon proofs
macro "charon_simp" args:Lean.Parser.Tactic.simpLemma,* : tactic =>
  `(tactic| simp only [evalFun, evalFunBody, evalStmtFuel, buildLocals,
              evalRValuePure, evalBinOpPure, evalOperandPure, evalPlacePure,
              writePlacePure, evalLit,
              List.replicate, List.foldl, List.zipWith, List.set, List.find?,
              beq_self_eq_true, getElem?_pos, List.getElem_cons_succ, List.getElem_cons_zero,
              List.length_cons, List.length_nil,
              Nat.reduceAdd, Nat.reduceLT, Nat.zero_add, $args,*])

-- ════════════════════════════════════════════════════════════════════════════
-- C1: return42
-- ════════════════════════════════════════════════════════════════════════════

#eval evalFun [] Return42Fun 10 [] ()

theorem charon_return42 :
    evalFun [] Return42Fun 10 [] at () |= .pureOutput (· = .int 42) :=
  ⟨.int 42, (), rfl, rfl⟩

