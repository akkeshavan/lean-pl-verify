-- ════════════════════════════════════════════════════════════════════════════
-- C3: neg
-- Charon adds an overflow-check local (var 3 = (x == I32::MIN)).
-- var 3 is dead for var 0; simp passes through transparently.
-- ════════════════════════════════════════════════════════════════════════════

#eval evalFun [] NegFun 10 [.int 5] ()
#eval evalFun [] NegFun 10 [.int (-3)] ()

theorem charon_neg (x : Int) :
    evalFun [] NegFun 10 [.int x] at () |= .pureOutput (· = .int (-x)) := by
  refine ⟨.int (-x), (), ?_, rfl⟩
  charon_simp NegFun

-- ════════════════════════════════════════════════════════════════════════════
-- C4: add  (overflow guard)
-- ════════════════════════════════════════════════════════════════════════════

#eval evalFun [] AddFun 10 [.int 3, .int 4] ()

theorem charon_add (x y : Int)
    (h : IntBounds.minI32 ≤ x + y ∧ x + y ≤ IntBounds.maxI32) :
    evalFun [] AddFun 10 [.int x, .int y] at () |= .pureOutput (· = .int (x + y)) := by
  refine ⟨.int (x + y), (), ?_, rfl⟩
  charon_simp AddFun
  rw [if_pos h]; rfl

theorem charon_add_nocrash (x y : Int)
    (h : IntBounds.minI32 ≤ x + y ∧ x + y ≤ IntBounds.maxI32) :
    evalFun [] AddFun 10 [.int x, .int y] at () |= .nocrash :=
  sat_pureOutput_nocrash (charon_add x y h)

