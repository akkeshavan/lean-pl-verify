    evalFun [] GcdFun 200 [.int 12, .int 8] at () |= .pureOutput (· = .int 4) :=
  ⟨.int 4, (), rfl, rfl⟩

theorem charon_gcd_100_75 :
    evalFun [] GcdFun 200 [.int 100, .int 75] at () |= .pureOutput (· = .int 25) :=
  ⟨.int 25, (), rfl, rfl⟩

theorem charon_gcd_35_21 :
    evalFun [] GcdFun 200 [.int 35, .int 21] at () |= .pureOutput (· = .int 7) :=
  ⟨.int 7, (), rfl, rfl⟩

theorem charon_gcd_nocrash_12_8 :
    evalFun [] GcdFun 200 [.int 12, .int 8] at () |= .nocrash :=
  sat_pureOutput_nocrash charon_gcd_12_8

