-- C17: pow  (x^n via loop: result * x^(n-i) = x^n invariant)
-- New function added to demonstrate pipeline extensibility.
-- ════════════════════════════════════════════════════════════════════════════

#eval evalFun [] PowFun 200 [.int 2, .int 10]  ()   -- 1024
#eval evalFun [] PowFun 200 [.int 3, .int 4]   ()   -- 81

/-- pow(x, 0) = 1 for any x — the loop never executes (i=0, n=0 → 0<0 false). -/
theorem charon_pow_zero (x : Int) :
    evalFun [] PowFun 10 [.int x, .int 0] at () |= .pureOutput (· = .int 1) :=
  ⟨.int 1, (), rfl, rfl⟩

