-- C18: gcd  (Euclidean algorithm via Rem)
-- Demonstrates: (1) Rem operator in our evaluator, (2) Charon UB-check
-- locals (vars 10-13) pass through simp transparently as dead assignments.
-- ════════════════════════════════════════════════════════════════════════════

#eval evalFun [] GcdFun 200 [.int 12, .int 8]   ()   -- 4
#eval evalFun [] GcdFun 200 [.int 100, .int 75]  ()   -- 25

/-- gcd(a, 0) = a for any a — the while condition y≠0 is immediately false. -/
theorem charon_gcd_zero (a : Int) :
    evalFun [] GcdFun 10 [.int a, .int 0] at () |= .pureOutput (· = .int a) :=
  ⟨.int a, (), rfl, rfl⟩

