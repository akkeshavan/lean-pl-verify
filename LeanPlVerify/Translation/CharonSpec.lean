-- ════════════════════════════════════════════════════════════════════════════
-- C6: max  (branching; Charon adds copy temporaries for a, b)
-- ════════════════════════════════════════════════════════════════════════════

#eval evalFun [] MaxFun 10 [.int 5, .int 3] ()
#eval evalFun [] MaxFun 10 [.int 2, .int 7] ()

theorem charon_max_ge (a b : Int) (h : a ≥ b) :
    evalFun [] MaxFun 10 [.int a, .int b] at () |= .pureOutput (· = .int a) := by
  refine ⟨.int a, (), ?_, rfl⟩
  charon_simp MaxFun, decide_eq_true h

theorem charon_max_lt (a b : Int) (h : a < b) :
    evalFun [] MaxFun 10 [.int a, .int b] at () |= .pureOutput (· = .int b) := by
  refine ⟨.int b, (), ?_, rfl⟩
  have hf : decide (a ≥ b) = false := decide_eq_false (not_le.mpr h)
  charon_simp MaxFun, hf

theorem charon_max_either (a b : Int) :
    evalFun [] MaxFun 10 [.int a, .int b] at () |=
      .pureOutput (fun v => v = .int a ∨ v = .int b) := by
  rcases Classical.em (a ≥ b) with h | h
  · exact sat_pureOutput_mono (fun _ hv => Or.inl hv) (charon_max_ge a b h)
  · exact sat_pureOutput_mono (fun _ hv => Or.inr hv) (charon_max_lt a b (not_le.mp h))

theorem charon_max_ge_both (a b : Int) :
    evalFun [] MaxFun 10 [.int a, .int b] at () |=
      .pureOutput (fun v => ∃ n : Int, v = .int n ∧ n ≥ a ∧ n ≥ b) := by
  rcases Classical.em (a ≥ b) with h | h
  · exact sat_pureOutput_mono (fun v hv => ⟨a, hv, le_refl a, h⟩) (charon_max_ge a b h)
  · exact sat_pureOutput_mono
        (fun v hv => ⟨b, hv, le_of_lt (not_le.mp h), le_refl b⟩)
        (charon_max_lt a b (not_le.mp h))

