-- ════════════════════════════════════════════════════════════════════════════

theorem charon_sub (x y : Int)
    (h : IntBounds.minI32 ≤ x - y ∧ x - y ≤ IntBounds.maxI32) :
    evalFun [] SubFun 10 [.int x, .int y] at () |= .pureOutput (· = .int (x - y)) := by
