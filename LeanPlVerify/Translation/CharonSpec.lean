-- C10: clamp
-- ════════════════════════════════════════════════════════════════════════════

theorem charon_clamp_mid (x lo hi : Int) (h1 : lo ≤ x) (h2 : x ≤ hi) :
    evalFun [] ClampFun 50 [.int x, .int lo, .int hi] at () |= .pureOutput (· = .int x) := by
  refine ⟨.int x, (), ?_, rfl⟩
  have hlt : decide (x < lo) = false := decide_eq_false (not_lt.mpr h1)
  have hgt : decide (x > hi) = false := decide_eq_false (not_lt.mpr h2)
  charon_simp ClampFun, hlt, hgt

theorem charon_clamp_lo (x lo hi : Int) (h : x < lo) :
    evalFun [] ClampFun 50 [.int x, .int lo, .int hi] at () |= .pureOutput (· = .int lo) := by
  refine ⟨.int lo, (), ?_, rfl⟩
  charon_simp ClampFun, decide_eq_true h

theorem charon_clamp_hi (x lo hi : Int) (h1 : lo ≤ x) (h2 : hi < x) :
    evalFun [] ClampFun 50 [.int x, .int lo, .int hi] at () |= .pureOutput (· = .int hi) := by
  refine ⟨.int hi, (), ?_, rfl⟩
  have hlt : decide (x < lo) = false := decide_eq_false (not_lt.mpr h1)
  charon_simp ClampFun, hlt, decide_eq_true h2

theorem charon_clamp_inrange (x lo hi : Int) (h : lo ≤ hi) :
    evalFun [] ClampFun 50 [.int x, .int lo, .int hi] at () |=
      .pureOutput (fun v => ∃ n : Int, v = .int n ∧ lo ≤ n ∧ n ≤ hi) := by
  rcases lt_trichotomy x lo with hlt | heq | hgt
  · exact sat_pureOutput_mono (fun v hv => ⟨lo, hv, le_refl lo, h⟩)
        (charon_clamp_lo x lo hi hlt)
  · rw [heq]
    exact sat_pureOutput_mono (fun v hv => ⟨lo, hv, le_refl lo, h⟩)
        (charon_clamp_mid lo lo hi (le_refl lo) h)
  · rcases Classical.em (x ≤ hi) with hle | hlt
    · exact sat_pureOutput_mono (fun v hv => ⟨x, hv, le_of_lt hgt, hle⟩)
          (charon_clamp_mid x lo hi (le_of_lt hgt) hle)
    · exact sat_pureOutput_mono (fun v hv => ⟨hi, hv, h, le_refl hi⟩)
          (charon_clamp_hi x lo hi (le_of_lt hgt) (not_le.mp hlt))

